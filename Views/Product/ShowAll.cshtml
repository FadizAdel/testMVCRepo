@model List<Product>
@{
    ViewData["Title"] = "ShowAll";
}

<table class="table table-bordered table-hover table-primary">
    @foreach(var item in Model)
    {
        <tr>
            <td>@item.Id</td>
            <td>@item.Name</td>
            <td>@item.Price $</td>
            <td>@item.Description</td>
            <td>@item.Image</td>
            <td>
                @Html.ActionLink("Details", "Details", new { id = item.Id })
            </td>
        </tr>
    }
</table>