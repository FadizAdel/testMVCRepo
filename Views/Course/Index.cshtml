@model List<Course>
@{
    ViewData["Title"] = "Index";
}

<h1>All Courses</h1>

<table class="table table-bordered table-hover">
    <tr>
        <th>Name</th>
        <th>Degree</th>
        <th>MinDegree</th>
        <th>Hours</th>
    </tr>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.Degree</td>
            <td>@item.MinDegree</td>
            <td>@item.Hours</td>
        </tr>
    }

</table>
<a class="btn btn-primary" asp-controller="Course" asp-action="Add">Add New Course</a>

